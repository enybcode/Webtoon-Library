generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model SecurityQuestion {
  id       Int    @id @default(autoincrement())
  question String
  users    User[]
}

model User {
  id                 Int              @id @default(autoincrement())
  username           String
  email              String           @unique
  password           String
  roleId             Int
  avatar             String?
  securityQuestionId Int
  securityAnswer     String
  isBanned           Boolean          @default(false)
  createdAt          DateTime         @default(now())
  role               Role             @relation(fields: [roleId], references: [id])
  securityQuestion   SecurityQuestion @relation(fields: [securityQuestionId], references: [id])
  userWebtoons       UserWebtoon[]
  comments           Comment[]
  notifications      Notification[]
}

model Genre {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  webtoons Webtoon[]
}

model ReadingStatus {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  webtoons     Webtoon[]
  userWebtoons UserWebtoon[]
}

model Webtoon {
  id                Int           @id @default(autoincrement())
  anilistId         Int?          @unique
  title             String
  synopsis          String?
  coverImage        String?
  author            String?
  totalChapters     Int?
  publicationStatus String?
  genreId           Int?
  readingStatusId   Int?
  createdAt         DateTime      @default(now())
  genre             Genre?        @relation(fields: [genreId], references: [id])
  readingStatus     ReadingStatus? @relation(fields: [readingStatusId], references: [id])
  userWebtoons      UserWebtoon[]
  comments          Comment[]
}

model UserWebtoon {
  id              Int           @id @default(autoincrement())
  userId          Int
  webtoonId       Int
  readingStatusId Int
  currentChapter  Int           @default(0)
  personalNote    String?
  rating          Int?
  addedAt         DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id])
  webtoon         Webtoon       @relation(fields: [webtoonId], references: [id])
  readingStatus   ReadingStatus @relation(fields: [readingStatusId], references: [id])

  @@unique([userId, webtoonId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  userId    Int
  webtoonId Int
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  webtoon   Webtoon  @relation(fields: [webtoonId], references: [id])
}

model NotifType {
  id            Int            @id @default(autoincrement())
  name          String         @unique
  notifications Notification[]
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      Int
  notifTypeId Int
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  notifType   NotifType @relation(fields: [notifTypeId], references: [id])
}
